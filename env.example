# RHID MCP Server — configurações
# Copie este arquivo para .env e preencha os valores reais

# Credenciais de acesso à API RHID
RHID_LOGIN=seu_email@email.com
RHID_PASSWORD=sua_senha_aqui
RHID_DOMAIN=                          # deixe vazio se não usar domínio separado
RHID_BASE_URL=https://www.rhid.com.br/v2/api.svc

# Transporte do servidor MCP
# "sse"   → HTTP/SSE para VPS (padrão)
# "stdio" → stdin/stdout para uso local com Claude Desktop
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8765